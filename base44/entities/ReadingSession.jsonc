{
  "name": "ReadingSession",
  "type": "object",
  "properties": {
    "reader_id": {
      "type": "string",
      "description": "User ID of the reader hosting the session"
    },
    "client_id": {
      "type": "string",
      "description": "User ID of the client, null until claimed via invite link"
    },
    "invite_token": {
      "type": "string",
      "description": "Unique token to invite the client to the session"
    },
    "spread_type": {
      "type": "string",
      "description": "e.g. 'celtic_cross', 'spirit_wheel_3ring'"
    },
    "deck_id": {
      "type": "string",
      "description": "ID of the deck used for this session"
    },
    "card_positions": {
      "type": "array",
      "description": "Array of objects like { card_id, x, y, rotation, revealed, label }",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "shared_interpretation": {
      "type": "string",
      "description": "Synchronized interpretation visible to both reader and client"
    },
    "room_url": {
      "type": "string",
      "description": "Whereby room URL for the client"
    },
    "host_room_url": {
      "type": "string",
      "description": "Whereby room URL for the host"
    },
    "status": {
      "type": "string",
      "enum": [
        "waiting",
        "active",
        "completed"
      ],
      "default": "waiting"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "reader_id",
    "spread_type"
  ]
}